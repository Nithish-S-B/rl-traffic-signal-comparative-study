<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- ============================================================
         VEHICLE TYPES
         ============================================================ -->
    <vType id="car"
           accel="2.6" decel="4.5" sigma="0.5"
           length="5.0" minGap="2.5" maxSpeed="13.89"
           guiShape="passenger"/>

    <vType id="truck"
           accel="1.5" decel="3.5" sigma="0.4"
           length="10.0" minGap="3.0" maxSpeed="11.11"
           guiShape="truck"/>

    <!-- ============================================================
         ROUTES  (straight-through only — no turns at this intersection)
         ============================================================ -->
    <route id="r_NS" edges="NtoC CtoS"/>
    <route id="r_SN" edges="StoC CtoN"/>
    <route id="r_EW" edges="EtoC CtoW"/>
    <route id="r_WE" edges="WtoC CtoE"/>

    <!-- ============================================================
         FLOWS
         period="10" means one vehicle every 10 seconds = 360 veh/hour
         period="15" means one vehicle every 15 seconds = 240 veh/hour
         Use 'period' (universally supported) instead of 'vehsPerHour'
         ============================================================ -->

    <!-- North → South  (high flow, one car every 10s) -->
    <flow id="flow_NS" type="car" route="r_NS"
          begin="0" end="1000" period="10"
          departLane="0" departSpeed="max"/>

    <!-- South → North  (high flow) -->
    <flow id="flow_SN" type="car" route="r_SN"
          begin="0" end="1000" period="10"
          departLane="0" departSpeed="max"/>

    <!-- East → West  (moderate flow, one car every 15s) -->
    <flow id="flow_EW" type="car" route="r_EW"
          begin="0" end="1000" period="15"
          departLane="0" departSpeed="max"/>

    <!-- West → East  (moderate flow) -->
    <flow id="flow_WE" type="car" route="r_WE"
          begin="0" end="1000" period="15"
          departLane="0" departSpeed="max"/>

    <!-- Truck flows (sparse) -->
    <flow id="flow_NS_truck" type="truck" route="r_NS"
          begin="50" end="950" period="60"
          departLane="0" departSpeed="max"/>

    <flow id="flow_EW_truck" type="truck" route="r_EW"
          begin="50" end="950" period="60"
          departLane="0" departSpeed="max"/>

</routes>
